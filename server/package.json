{
  "name": "@lazyhunter/server",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "worker": "bun src/jobs/workers/cronNightlyHunt.ts",
    "db:migrate": "bunx prisma migrate dev",
    "db:push": "bunx prisma db push",
    "db:studio": "bunx prisma studio",
    "apischema": "bunx openapi-typescript http://localhost:3000/doc -o ../client/src/lib/api/apiSchema.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "prisma": "^7.6.0",
    "zod-prisma-types": "^3.3.11"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.3.0",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.6.0",
    "@scalar/hono-api-reference": "^0.10.13",
    "better-auth": "^1.5.6",
    "cheerio": "^1.2.0",
    "croner": "^10.0.1",
    "dotenv": "^17.2.4",
    "hono": "4.12.3",
    "install": "^0.13.0",
    "p-map": "^7.0.4",
    "pg": "^8.18.0",
    "sharp": "^0.34.5",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  }
}
